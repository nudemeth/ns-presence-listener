# ── Polling ───────────────────────────────────────────────────────────────────
# How often to check presence (milliseconds). Default: 30000 (30 seconds)
POLL_INTERVAL_MS=30000

# ── Webhook ───────────────────────────────────────────────────────────────────
# URL to POST to on game start/stop. Leave blank to disable.
WEBHOOK_URL=

# Optional HMAC secret. If set, each request includes X-Hub-Signature-256.
WEBHOOK_SECRET=

# ── Steam Presence ────────────────────────────────────────────────────────────
# Your Steam account credentials. When set, your Steam profile will show the
# Nintendo Switch game you're currently playing as a non-Steam game.
# Leave both blank to disable Steam integration.
# Note: On first login from a new device, Steam Guard will prompt for a code
# on the terminal (email code or authenticator code, depending on your setup).
STEAM_USERNAME=
STEAM_PASSWORD=
# Path to store the Steam refresh token (avoids Steam Guard on subsequent runs).
# Default: .steam-refresh-token (in project root)
STEAM_TOKEN_FILE=

# ── Discord Rich Presence ──────────────────────────────────────────────────────
# Client ID from https://discord.com/developers/applications
# Steps: Create Application → copy Client ID → paste here.
# Leave blank to disable Discord integration.
DISCORD_CLIENT_ID=

# ── Logging ───────────────────────────────────────────────────────────────────
# Path to the log file. Default: presence.log (in project root)
LOG_FILE=presence.log

# ── Advanced ──────────────────────────────────────────────────────────────────
# Path to the stored auth token file. Default: .tokens.json (in project root)
TOKEN_FILE=.tokens.json
